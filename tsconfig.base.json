{
  "compileOnSave": false,
  "compilerOptions": {
    "rootDir": ".",
    "sourceMap": true,
    "declaration": false,
    "moduleResolution": "node",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "es2015",
    "module": "esnext",
    "lib": ["es2017", "dom"],
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@nx-stackblitz/backend/demo/core/application-services": [
        "libs/backend/demo/core/application-services/src/index.ts"
      ],
      "@nx-stackblitz/backend/demo/core/domain-services": [
        "libs/backend/demo/core/domain-services/src/index.ts"
      ],
      "@nx-stackblitz/backend/demo/infrastructure": [
        "libs/backend/demo/infrastructure/src/index.ts"
      ],
      "@nx-stackblitz/backend/demo/shell": [
        "libs/backend/demo/shell/src/index.ts"
      ],
      "@nx-stackblitz/backend/demo/ui-graphql": [
        "libs/backend/demo/ui-graphql/src/index.ts"
      ],
      "@nx-stackblitz/backend/demo/ui-rest": [
        "libs/backend/demo/ui-rest/src/index.ts"
      ],
      "@nx-stackblitz/frontend/demo/portal/data-access": [
        "libs/frontend/demo/portal/data-access/src/index.ts"
      ],
      "@nx-stackblitz/frontend/demo/portal/shell": [
        "libs/frontend/demo/portal/shell/src/index.ts"
      ],
      "@nx-stackblitz/frontend/demo/public/data-access": [
        "libs/frontend/demo/public/data-access/src/index.ts"
      ],
      "@nx-stackblitz/frontend/demo/public/shell": [
        "libs/frontend/demo/public/shell/src/index.ts"
      ],
      "@nx-stackblitz/frontend/demo/shared/data-access": [
        "libs/frontend/demo/shared/data-access/src/index.ts"
      ],
      "@nx-stackblitz/frontend/demo/shared/shell": [
        "libs/frontend/demo/shared/shell/src/index.ts"
      ],
      "@nx-stackblitz/shared/demo/domain": [
        "libs/shared/demo/domain/src/index.ts"
      ],
      "@nx-stackblitz/shared/ui": ["libs/shared/ui/src/index.ts"],
      "@nx-stackblitz/shared/utils": ["libs/shared/utils/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "tmp"]
}
